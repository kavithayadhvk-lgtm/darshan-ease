{
  "name": "darshanease",
  "version": "1.0.0",
  "private": true,
  "description": "DarshanEase - Temple Darshan Booking System using microservices architecture",
  "scripts": {
    "start:gateway": "cd api-gateway && npm start",
    "start:auth": "cd services/auth-service && npm start",
